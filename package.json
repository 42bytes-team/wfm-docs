{
  "name": "warframe-market-docs",
  "version": "0.0.0",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "start": "docusaurus start --port 3000",
    "start:wfm": "tsx scripts/start-wfm.ts",
    "start:wfm:no-open": "DOCS_OPEN=false tsx scripts/start-wfm.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,css,json,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,css,json,md,mdx}\"",
    "build": "docusaurus build",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --host 0.0.0.0 --port 3001",
    "write-translations": "docusaurus write-translations",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@easyops-cn/docusaurus-search-local": "^0.55.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0",
    "yarn": ">=4.14.1 <5"
  }
}
